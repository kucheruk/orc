#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TARGET_WORKSPACE="${ORC_WORKSPACE:-$PWD}"

has_workspace_flag=0
for arg in "$@"; do
  if [[ "$arg" == "--workspace" ]]; then
    has_workspace_flag=1
    break
  fi
done

if [[ "$has_workspace_flag" -eq 1 ]]; then
  exec uv run --project "$SCRIPT_DIR" python "$SCRIPT_DIR/orc.py" "$@"
fi

exec uv run --project "$SCRIPT_DIR" python "$SCRIPT_DIR/orc.py" --workspace "$TARGET_WORKSPACE" "$@"
